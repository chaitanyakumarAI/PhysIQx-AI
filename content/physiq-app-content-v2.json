  "physiqScore": {
    "description": "A composite 0-100 score reflecting training consistency, load progression, recovery and hydration adherence.",
    "pillars": [
      {
        "id": "training",
        "name": "Training",
        "signals": ["volume_trend_pct", "rpe_trend", "lift_stall_sessions"],
        "conditions": {
          "low": "Volume is down and RPE is climbing — that combination usually means under-recovery. Consider a deload week before pushing more weight.",
          "medium": "Training load is steady. Add small weekly increments (2.5-5%) to keep progressing.",
          "high": "Volume up and RPE steady — you're in a strong progression window. Add one heavy top set to your primary lift this week."
        }
      },
      {
        "id": "consistency",
        "name": "Consistency",
        "signals": ["weekly_session_completion_pct", "streak_days"],
        "conditions": {
          "low": "You've missed more than half your planned sessions this week. A short, easy session today beats skipping entirely — it protects the habit.",
          "medium": "Solid attendance this week. One more session would push your streak past your personal best.",
          "high": "Perfect week — every planned session logged. This is what compounds into results."
        }
      },
      {
        "id": "recovery",
        "name": "Recovery",
        "signals": ["rpe_trend", "session_spacing_hours", "physiq_score_delta"],
        "conditions": {
          "low": "Signs of accumulated fatigue — RPE rising three sessions in a row. Prioritize sleep and consider a lighter session tomorrow.",
          "medium": "Recovery looks balanced against your current training load.",
          "high": "Recovery and training are well aligned right now — protect this by not adding extra sessions tonight."
        }
      },
      {
        "id": "hydration",
        "name": "Hydration",
        "signals": ["hydration_pct_today"],
        "conditions": {
          "low": "Hydration has been under 50% of goal before recent sessions — this raises cramp risk and can quietly cost you reps.",
          "medium": "Hydration is close to goal most days — keep front-loading water before sessions.",
          "high": "Hydration goal consistently met — this is supporting your strength output well."
        }
      }
    ]
  },

  "aiCoachRules": {
    "description": "Each rule fires ONLY when its condition is true against the user's real logged data. Priority determines which single message shows when multiple conditions are true in the same session (higher number = shown first). No message should be selected at random when a specific data-driven rule applies.",
    "rules": [
      {
        "id": "hydration_critical",
        "priority": 90,
        "condition": "hydration_pct_today < 50 AND session_scheduled_today == true",
        "message": "You're under 50% of today's hydration goal. Low fluid levels before training raise your risk of cramps and can cost you reps late in the session — drink 500ml now before you start."
      },
      {
        "id": "hydration_moderate",
        "priority": 40,
        "condition": "hydration_pct_today >= 50 AND hydration_pct_today < 80",
        "message": "You're at {{hydration_pct_today}}% of today's hydration goal. A bit more water before your session helps you hold output through your last sets."
      },
      {
        "id": "hydration_met",
        "priority": 10,
        "condition": "hydration_pct_today >= 100",
        "message": "Hydration goal already hit today — good foundation heading into your session."
      },
      {
        "id": "training_peak",
        "priority": 80,
        "condition": "volume_trend_pct > 10 AND rpe_trend <= 0",
        "message": "Volume is up {{volume_trend_pct}}% and RPE has stayed flat — that's a strong progression window. Add one heavy top set on {{primary_lift}} this session."
      },
      {
        "id": "overtraining_risk",
        "priority": 95,
        "condition": "volume_trend_pct > 10 AND rpe_trend > 1.5",
        "message": "Your volume is climbing but so is your RPE — three sessions in a row now. This pattern often precedes a stall or injury. Consider a lighter session or an extra rest day before your next heavy lift."
      },
      {
        "id": "lift_plateau",
        "priority": 70,
        "condition": "lift_stall_sessions >= 3",
        "message": "{{lift_name}} hasn't moved in {{lift_stall_sessions}} sessions. Try a rep-range shift for two weeks, or add just 2.5kg and hold there before pushing further."
      },
      {
        "id": "consistency_low",
        "priority": 85,
        "condition": "sessions_missed_this_week >= 2 AND weekly_session_completion_pct < 50",
        "message": "You've missed {{sessions_missed_this_week}} sessions this week. Rather than trying to make them all up, jump back in with today's session as planned — consistency matters more than making up lost volume."
      },
      {
        "id": "consistency_streak_milestone",
        "priority": 60,
        "condition": "streak_days > 0 AND streak_days % 7 == 0",
        "message": "{{streak_days}}-day streak — that's {{streak_weeks}} full weeks without missing a planned session."
      },
      {
        "id": "pr_dry_spell",
        "priority": 50,
        "condition": "pr_count_this_month == 0 AND days_since_last_pr > 21",
        "message": "It's been {{days_since_last_pr}} days since your last PR. That's normal during a volume-building phase, but if {{primary_lift}} still feels heavy at the same reps, a deload might unlock the next jump."
      },
      {
        "id": "pr_streak",
        "priority": 75,
        "condition": "pr_count_this_month >= 3",
        "message": "{{pr_count_this_month}} PRs this month. Momentum is real right now — this is a good window to test a new top set on {{primary_lift}}, with a spotter if you're going heavy."
      },
      {
        "id": "physiq_score_drop",
        "priority": 88,
        "condition": "physiq_score_delta <= -5",
        "message": "Your PhysIQ Score dropped {{physiq_score_delta_abs}} points this week — usually a mix of missed sessions and rising RPE. Consider a lighter week to reset before pushing load again."
      },
      {
        "id": "physiq_score_rise",
        "priority": 55,
        "condition": "physiq_score_delta >= 5",
        "message": "Your PhysIQ Score climbed {{physiq_score_delta}} points this week — training, consistency and recovery are all pulling in the same direction."
      },
      {
        "id": "missed_session_recovery",
        "priority": 65,
        "condition": "sessions_missed_yesterday == true AND sessions_missed_this_week < 2",
        "message": "No session logged yesterday — that's fine. Today's session is scaled slightly lighter by the AI to ease back in without adding fatigue."
      },
      {
        "id": "default_neutral",
        "priority": 0,
        "condition": "no other rule matched",
        "message": "Logged and on track. Keep the same effort today and let the week add up."
      }
    ]
  },

  "nutritionTips": {
    "trackingStatus": "Nutrition is not tracked in-app. These tips are shown opportunistically, not based on logged data.",
    "deliveryRule": "Show at most 1 tip per day, with roughly a 1-in-4 chance after finishing a workout or opening the Insights tab. Never phrase these as if they're based on the user's actual intake.",
